# 이 파일을 .env로 복사한 뒤 실제 값을 채운다 (.env는 커밋하지 않는다).
# EXPO_PUBLIC_ 접두어가 붙은 값만 앱 번들에 주입된다 — 반드시 리터럴로 접근해야 치환된다.

# 웹 앱 URL (미설정 시 dev는 같은 머신 3000 포트로 폴백)
EXPO_PUBLIC_WEB_URL=

# --- Google OAuth client ID (Google Cloud Console) ---
# 플랫폼별 client ID. iOS는 reversed 스킴을 redirect로 쓰므로 iOS용을 반드시 채운다.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# --- Kakao (Kakao Developers Console) ---
# REST API 키(Native 키 아님). 콘솔에서 OIDC 활성화 + redirect URI(landit://oauthredirect) 등록 +
# client_secret "사용 안 함"으로 둬야 기기에서 PKCE 토큰 교환이 된다.
EXPO_PUBLIC_KAKAO_REST_API_KEY=

# --- (선택) OAuth redirect URI 강제 지정 ---
# 미설정 시 landit://oauthredirect 로 자동 생성. 특수 배포/터널 환경에서만 채운다.
EXPO_PUBLIC_AUTH_REDIRECT_URI=

# Apple 로그인은 별도 키가 없다 — app.json의 expo-apple-authentication 플러그인 +
# Apple Developer의 Sign in with Apple capability로 동작한다.
