NEXT_PUBLIC_API_BASE_URL=백엔드_API_주소

# Deepgram STT — 서버에서만 사용(임시 토큰 발급). 클라이언트에 노출 금지
DEEPGRAM_API_KEY=딥그램_API_키

# OpenRouter TTS — 서버에서만 사용(합성 프록시). 클라이언트에 노출 금지
OPENROUTER_API_KEY=오픈라우터_API_키

# 브라우저 단독 소셜 로그인(웹 폴백) — 앱 없이 로그인/테스트할 때 쓴다.
# client_id는 백엔드 LANDIT_AUTH_OIDC_*_AUDIENCES와 반드시 일치해야 하고, redirect uri는 각 콘솔에 등록해야 한다.

# 구글 — Google Cloud Console의 "웹" OAuth 클라이언트
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=구글_웹_클라이언트_ID
# 선택 — 클라이언트 유형이 secret을 요구할 때만. PKCE 전용이면 비워둔다. 서버에서만 사용
GOOGLE_CLIENT_SECRET=
# 미설정 시 현재 origin 기준 http://<origin>/auth/google/callback 을 자동으로 쓴다
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# 카카오 — 카카오 개발자 콘솔에서 OpenID Connect 활성화 필요
NEXT_PUBLIC_KAKAO_JS_KEY=카카오_자바스크립트_키
# code→id_token 교환용(서버에서만 사용)
NEXT_PUBLIC_KAKAO_REST_API_KEY=카카오_REST_API_키
# 선택 — 카카오 콘솔에서 client secret을 켰을 때만. 서버에서만 사용
KAKAO_CLIENT_SECRET=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback